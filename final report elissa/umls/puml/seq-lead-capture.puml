@startuml seq-lead-capture
' Robustness / Boundary-Control-Entity (BCE) sequence diagram.
' Visual skin kept black-and-white / Times New Roman to match the report
' (enforced by _build/restyle_seq.py); the structure follows the BCE rules.
skinparam backgroundColor transparent
skinparam shadowing false
skinparam maxMessageSize 200
skinparam defaultFontName Times New Roman
skinparam sequence {
  ArrowColor #000000
  ArrowFontColor #000000
  LifeLineBorderColor #333333
  LifeLineBackgroundColor #FFFFFF
  ParticipantBackgroundColor #FFFFFF
  ParticipantFontColor #000000
  ParticipantBorderColor #333333
  ActorBackgroundColor #FFFFFF
  ActorBorderColor #333333
  DatabaseBackgroundColor #FFFFFF
  DatabaseBorderColor #333333
}
hide footbox
autonumber
title Lead capture

actor ":SalesOperator" as Operator
boundary ":InterfaceLeadCapture" as UI
control ":ControllerCapture" as Capture
control ":WorkflowN8N" as N8N
control ":ControllerAI" as AI
database "Odoo CRM" as Odoo

Operator -> UI : submitCustomerMessage(message)
UI -> Capture : captureLead(message, source)
Capture -> N8N : forwardLeadCapture(message)
N8N -> AI : extractFields(message)
AI --> N8N : extractedFields(name, email, phone, interest, priority)
N8N -> Odoo : readOpportunities()
Odoo --> N8N : existingOpportunities
N8N -> N8N : checkDuplicate(email, phone)
alt new lead
  N8N -> Odoo : createOpportunity(fields)
  Odoo --> N8N : opportunityCreated(id)
  N8N --> Capture : leadCreated(opportunity)
  Capture --> UI : showCreatedLead(opportunity)
else duplicate found
  N8N --> Capture : duplicateDetected(match)
  Capture --> UI : showDuplicateNotice(match)
end
@enduml
