@startuml seq-followup
' Robustness / Boundary-Control-Entity (BCE) sequence diagram.
' Visual skin kept black-and-white / Times New Roman to match the report
' (enforced by _build/restyle_seq.py); the structure follows the BCE rules.
skinparam backgroundColor transparent
skinparam shadowing false
skinparam maxMessageSize 200
skinparam defaultFontName Times New Roman
skinparam sequence {
  ArrowColor #000000
  ArrowFontColor #000000
  LifeLineBorderColor #333333
  LifeLineBackgroundColor #FFFFFF
  ParticipantBackgroundColor #FFFFFF
  ParticipantFontColor #000000
  ParticipantBorderColor #333333
  ActorBackgroundColor #FFFFFF
  ActorBorderColor #333333
  DatabaseBackgroundColor #FFFFFF
  DatabaseBorderColor #333333
}
hide footbox
autonumber
title Smart follow-up

actor ":SalesOperator" as Operator
boundary ":InterfaceFollowUp" as UI
control ":ControllerFollowUp" as FollowUp
control ":WorkflowN8N" as N8N
control ":ControllerAI" as AI
database "Odoo CRM" as Odoo

Operator -> UI : openFollowUpCenter()
UI -> FollowUp : requestFollowUps()
FollowUp -> N8N : forwardFollowUpRequest()
N8N -> Odoo : readOpportunities()
Odoo --> N8N : opportunities
N8N -> N8N : detectInactiveLeads(opportunities, 7)
loop for each inactive lead
  N8N -> AI : draftFollowUpMessage(lead)
  AI --> N8N : followUpMessage(text)
  N8N -> Odoo : saveFollowUpMessage(leadId, text)
  Odoo --> N8N : opportunityUpdated
end
N8N --> FollowUp : followUpResults(messages)
FollowUp --> UI : showFollowUpDrafts(messages)
@enduml
