@startuml seq-assistant
' Robustness / Boundary-Control-Entity (BCE) sequence diagram.
' Visual skin kept black-and-white / Times New Roman to match the report
' (enforced by _build/restyle_seq.py); the structure follows the BCE rules.
skinparam backgroundColor transparent
skinparam shadowing false
skinparam maxMessageSize 200
skinparam defaultFontName Times New Roman
skinparam sequence {
  ArrowColor #000000
  ArrowFontColor #000000
  LifeLineBorderColor #333333
  LifeLineBackgroundColor #FFFFFF
  ParticipantBackgroundColor #FFFFFF
  ParticipantFontColor #000000
  ParticipantBorderColor #333333
  ActorBackgroundColor #FFFFFF
  ActorBorderColor #333333
  DatabaseBackgroundColor #FFFFFF
  DatabaseBorderColor #333333
}
hide footbox
autonumber
title AI CRM assistant

actor ":User" as User
boundary ":InterfaceAssistant" as UI
control ":ControllerAssistant" as Assistant
control ":WorkflowN8N" as N8N
control ":ControllerAI" as AI
database "Odoo CRM" as Odoo

User -> UI : askQuestion(question)
UI -> Assistant : sendQuestion(question, sessionId)
Assistant -> N8N : forwardQuestion(question)
N8N -> AI : interpret(question, toolList)
AI --> N8N : selectedTool(tool, args)
alt read request
  N8N -> Odoo : listOpportunities(args)
  Odoo --> N8N : opportunities
else update request
  N8N -> Odoo : updateOpportunity(id, changes)
  Odoo --> N8N : opportunityUpdated
end
N8N -> AI : composeAnswer(toolResult)
AI --> N8N : finalAnswer(text)
N8N --> Assistant : answer(text)
Assistant --> UI : displayAnswer(text)
@enduml
