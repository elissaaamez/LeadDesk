@startuml seq-analytics
' Robustness / Boundary-Control-Entity (BCE) sequence diagram.
' Visual skin kept black-and-white / Times New Roman to match the report
' (enforced by _build/restyle_seq.py); the structure follows the BCE rules.
skinparam backgroundColor transparent
skinparam shadowing false
skinparam maxMessageSize 200
skinparam defaultFontName Times New Roman
skinparam sequence {
  ArrowColor #000000
  ArrowFontColor #000000
  LifeLineBorderColor #333333
  LifeLineBackgroundColor #FFFFFF
  ParticipantBackgroundColor #FFFFFF
  ParticipantFontColor #000000
  ParticipantBorderColor #333333
  ActorBackgroundColor #FFFFFF
  ActorBorderColor #333333
  DatabaseBackgroundColor #FFFFFF
  DatabaseBorderColor #333333
}
hide footbox
autonumber
title Dashboard analytics summary

actor ":Manager" as Manager
boundary ":InterfaceDashboard" as UI
control ":ControllerAnalytics" as Analytics
control ":WorkflowN8N" as N8N
control ":ControllerAI" as AI
database "Odoo CRM" as Odoo

Manager -> UI : openDashboard()
UI -> Analytics : requestSummary()
Analytics -> N8N : forwardSummaryRequest()
N8N -> Odoo : readOpportunities()
Odoo --> N8N : opportunities
N8N -> N8N : computeIndicators(opportunities)
N8N -> AI : writeSummary(indicators)
AI --> N8N : readableSummary(text)
N8N --> Analytics : summaryResult(indicators, text)
Analytics --> UI : showDashboard(indicators, summary)
@enduml
