      "id": "f9a61694-64a2-419d-a44e-0e953761fb10",
      "name": "Get many items",
      "credentials": {
        "odooApi": {
          "id": "Sv6udoSjCErFqjcV",
          "name": "Odoo account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const leads = $input.all().map(item => item.json);\nconst now = new Date();\n\nconst inactiveAfterDays = 7;\n\n// Step 1: filter inactive leads\nconst inactiveLeads = leads\n  .filter(lead => lead.type === \"opportunity\")\n  .map(lead => {\n    const lastUpdate = new Date(lead.write_date || lead.create_date);\n    const diffDays = (now - lastUpdate) / (1000 * 60 * 60 * 24);\n\n    return {\n      ...lead,\n      inactive_days: Math.floor(diffDays)\n    };\n  })\n  .filter(lead => lead.inactive_days >= inactiveAfterDays);\n\n// Step 2: remove duplicates by email\nconst uniqueLeadsMap = {};\n\ninactiveLeads.forEach(lead => {\n  const email = (lead.email_from || \"\").toLowerCase();\n\n  if (!email) return;\n\n  // keep the MOST RECENT lead only\n  if (\n    !uniqueLeadsMap[email] ||\n    new Date(lead.write_date) > new Date(uniqueLeadsMap[email].write_date)\n  ) {\n    uniqueLeadsMap[email] = lead;\n  }\n});\n\n// Step 3: return clean list\nconst finalLeads = Object.values(uniqueLeadsMap).map(lead => ({\n  json: {\n    id: lead.id,\n    name: lead.name,\n    email: lead.email_from,\n    phone: lead.phone,\n    inactive_days: lead.inactive_days,\n    status: \"inactive\"\n  }\n}));\n\nreturn finalLeads;"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        352,
        0
      ],
      "id": "7e8f4170-a419-4139-9192-769df40f1738",
      "name": "Detect Inactive Leads"
