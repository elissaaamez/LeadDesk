      ],
      "id": "6921c9e8-bfbd-4257-a500-a9ad448ba028",
      "name": "Ollama Model",
      "credentials": {
        "ollamaApi": {
          "id": "1m5rFaiuChafuLdv",
          "name": "Ollama account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "return $input.all().map(item => {\n  const raw = item.json.text || item.json.output || item.json.response || \"\";\n\n  let cleaned = raw\n    .replace(/```json/g, \"\")\n    .replace(/```/g, \"\")\n    .trim();\n\n  let data;\n\n  try {\n    data = JSON.parse(cleaned);\n  } catch (error) {\n    data = {\n      lead_id: null,\n      name: \"\",\n      email: \"\",\n      inactive_days: null,\n      follow_up_message: raw\n    };\n  }\n\n  return {\n    json: data\n  };\n});"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        960,
        0
      ],
      "id": "dcd97d3d-b728-4693-83a5-e077b7fb9d5e",
      "name": "Format Follow-Up Result"
    },
    {
      "parameters": {
        "jsCode": "return $input.all().map(item => {\n  const lead = item.json;\n\n  return {\n    json: {\n      ...lead,\n      chatInput:\n`Generate a CRM follow-up message for this inactive lead.\n\nReturn ONLY valid JSON with this exact structure:\n{\n  \"lead_id\": ${lead.id},\n  \"name\": \"${lead.name}\",\n  \"email\": \"${lead.email}\",\n  \"inactive_days\": ${lead.inactive_days},\n  \"follow_up_message\": \"\"\n}\n\nRules:\n- follow_up_message must start with: Dear ${lead.name},\n- Keep it polite and professional.\n- Mention that we are following up regarding their interest.\n- Ask if they would like to continue the discussion.\n- Do not use placeholders like [Name] or [Your Name].\n- Do not invent company details.\n- End with: Best regards, Sales Team\n- Return JSON only.`\n    }\n  };\n});"
      },
      "type": "n8n-nodes-base.code",
